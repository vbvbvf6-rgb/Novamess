auto-install-peers=false
strict-peer-dependencies=false
# Render (and some other non-Replit hosts) don't reliably preserve pnpm's
# symlinked node_modules structure between the build and runtime stages,
# which causes "Cannot find package" errors for deps that esbuild
# externalizes (e.g. @aws-sdk/client-s3) instead of bundling. Hoisting
# flattens node_modules like npm/yarn so those externalized deps are found
# as real files at runtime regardless of how the host copies the build.
node-linker=hoisted
