{
  "version": 2,
  "installCommand": "pnpm install",
  "buildCommand": "BASE_PATH=/ pnpm --filter @workspace/pulse run build && pnpm --filter @workspace/api-server run build",
  "outputDirectory": "artifacts/pulse/dist/public",
  "framework": null,
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/server" },
    { "source": "/bot/:path*", "destination": "/api/server" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "no-store" }]
    }
  ],
  "functions": {
    "api/server.ts": { "maxDuration": 60, "memory": 1024 }
  }
}
